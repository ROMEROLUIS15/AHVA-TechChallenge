@model BlockedViewModel
@{
    ViewData["Title"] = "Cuenta bloqueada";
}
<div class="auth-stack">
    <div class="auth-card text-card">
        <div class="auth-icon-badge" style="background:#e8eefc;color:#2c5fc4;">@Html.Raw(IconSvg.Blocked)</div>
        <div class="auth-title">Cuenta bloqueada temporalmente</div>
        <p class="auth-text">
            Has excedido el número máximo de intentos fallidos (@Model.MaxAttempts).
            Por seguridad, tu cuenta ha sido bloqueada durante @Model.LockoutMinutes minutos.
            Intente nuevamente más tarde.
        </p>
        <a class="btn-primary-ceplan" style="margin-top:18px;" asp-controller="Account" asp-action="Login">Volver al inicio de sesión</a>
    </div>
</div>
