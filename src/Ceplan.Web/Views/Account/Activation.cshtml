@{
    ViewData["Title"] = "Activación de cuenta";
}
<div class="auth-stack">
    <div class="auth-card text-card">
        <div class="auth-icon-badge">@Html.Raw(IconSvg.Rocket)</div>
        <div class="auth-title">¡Bienvenida, July!</div>
        <p class="auth-text">Su cuenta en el aplicativo X está activada.</p>
        <p class="auth-text">Ya puede iniciar sesión.</p>
        <a class="btn-primary-ceplan" style="margin-top:18px;" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
    </div>
</div>
